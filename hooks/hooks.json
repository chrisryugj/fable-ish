{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py\"",
            "timeout": 10,
            "statusMessage": "Classifying fable-ish task"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|PowerShell|Edit|Write|MultiEdit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_use.py\"",
            "timeout": 10,
            "statusMessage": "Checking fable-ish guardrails"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^(Bash|PowerShell|Edit|Write|MultiEdit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/permission_request.py\"",
            "timeout": 10,
            "statusMessage": "Checking fable-ish approval guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|PowerShell|Edit|Write|MultiEdit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use.py\"",
            "timeout": 10,
            "statusMessage": "Recording fable-ish evidence"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "^(Bash|PowerShell|Edit|Write|MultiEdit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use.py\"",
            "timeout": 10,
            "statusMessage": "Recording fable-ish failure evidence"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/stop_gate.py\"",
            "timeout": 10,
            "statusMessage": "Reviewing fable-ish completion"
          }
        ]
      }
    ]
  }
}
